# Backend API base URL
# Local split dev: http://localhost:3000
# Production split deploy: your Render backend URL
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Auth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"

# Database for server-rendered pages still using direct DB access
MONGODB_URI="mongodb://127.0.0.1:27017/pantry-guardian"

# Optional local OCR service used by the OCR test page
RECEIPT_OCR_API_URL="http://localhost:8000"
RECEIPT_OCR_OCR_PATH="/ocr/"
